DATABASE_URL=postgresql+psycopg://mediaintel:mediaintel@localhost:5432/mediaintel
OPENAI_API_KEY=
OPENAI_MODEL_ITEM_CLASSIFIER=gpt-5-mini
OPENAI_MODEL_REPORT=gpt-5.2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSION=1536
NEWS_SOURCE_CONFIG=configs/sources.newspapers.yaml
X_SOURCE_CONFIG=configs/sources.x_handles.yaml
X_BEARER_TOKEN=
REPORT_OUTPUT_DIR=reports/generated
OPERATOR_API_TOKEN=
RAG_CHUNK_MAX_CHARS=1200
RAG_CHUNK_OVERLAP_CHARS=200

# Ollama analyser — local CPU by default; switch to a -cloud tag after
# `ollama signin` for GPU-hosted bigger models (e.g. Gemma 3 27B).
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma2:2b
